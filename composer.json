{
    "name": "mobicardsystems/laravel-scanapi",
    "description": "Mobicard card scanning package for Laravel",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Frank Njauke",
            "email": "support@mobicardsystems.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/validation": "^11.0|^12.0|^13.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "MobicardApi\\ScanApi\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "MobicardApi\\ScanApi\\ScanApiServiceProvider"
            ],
            "aliases": {
                "ScanApi": "MobicardApi\\ScanApi\\Facades\\ScanApi"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}